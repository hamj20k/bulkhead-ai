# Copy this file to `.env` and paste in the key(s) for the provider(s) you'll use.
#   cp .env.example .env
# `.env` is gitignored — your real keys never get committed.
# You only need the key for the provider whose model you pick in the demo/GUI.

# Groq — free tier at https://console.groq.com  (used by demo/python/live_groq.py and the GUI)
GROQ_API_KEY=

# Anthropic — https://console.anthropic.com  (only needed if you pick a claude-* model)
ANTHROPIC_API_KEY=
